# ===== Frontend (VITE_* — safe for browser) =====
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_LIVEKIT_URL=wss://your-livekit-cloud.livekit.cloud
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_ENV=development

# ===== Backend / Agent =====
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
LIVEKIT_URL=wss://your-livekit-cloud.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
BEY_API_KEY=
BEY_AVATAR_ID=f30d7eef-6e71-433f-938d-cecdd8c0b653
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=694f9389-aac1-45b6-b726-9d9369183238
CARTESIA_SPEED=1.15
OPENROUTER_API_KEY=
OPENROUTER_MODEL=moonshotai/kimi-k2-0905
OPENROUTER_REASONING_ENABLED=true
OPENROUTER_REASONING_EFFORT=xhigh
OPENROUTER_REASONING_EXCLUDE=true
# Eval harness (eval_scenarios.py) — separate from voice agent model
EVAL_MODEL=moonshotai/kimi-k2-0905
EVAL_REASONING_EFFORT=xhigh
EVAL_REASONING_EXCLUDE=true
EVAL_SCENARIO_TIMEOUT=300
# Comma-separated; add ports your Vite dev server uses (e.g. 5174 if 5173 is taken)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
LOG_LEVEL=INFO
# Set to 1 for verbose LiveKit + HTTP logs in the agent terminal (STT/TTS/LLM pipeline detail).
VERBOSE_AGENT_LOGS=
DEMO_MODE_ENABLED=true
